# ==============================================================
#  NEW WINE CHURCH — .gitignore racine
#  Sécurité maximale : aucun secret, aucun build, aucun cache
# ==============================================================

# === Backend Laravel ===
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/storage/app/public/*
!backend/storage/app/public/.gitkeep
backend/storage/framework/cache/*
!backend/storage/framework/cache/.gitkeep
backend/storage/framework/sessions/*
!backend/storage/framework/sessions/.gitkeep
backend/storage/framework/testing/*
!backend/storage/framework/testing/.gitkeep
backend/storage/framework/views/*
!backend/storage/framework/views/.gitkeep
backend/storage/logs/*
!backend/storage/logs/.gitkeep
backend/.phpunit.cache
backend/.phpunit.result.cache
backend/Homestead.json
backend/Homestead.yaml
backend/auth.json
backend/.env
backend/.env.*
!backend/.env.example
backend/.env.backup
backend/.env.production
backend/.phpactor.json
backend/.idea
backend/.vscode

# === Frontend Vite/React ===
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/build/
frontend/coverage/
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.eslintcache
frontend/*.local

# === Windows shortcuts / OS clutter ===
*.lnk

# === IDE & OS ===
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# === Logs & temporaires ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Claude Code ===
.claude/
