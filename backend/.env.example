# ==============================================================
#  NEW WINE CHURCH — Template de configuration (.env.example)
#  Copier en .env puis personnaliser les valeurs sensibles
# ==============================================================

APP_NAME="New Wine Church"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Abidjan
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=newwinechurch
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=newwinechurch
REVERB_APP_KEY=nwc_local_key
REVERB_APP_SECRET=nwc_local_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM_ADDRESS="contact@newinechurch.org"
MAIL_FROM_NAME="${APP_NAME}"

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_EXPIRY=3600

SCOUT_DRIVER=database
MEDIA_DISK=public
TELESCOPE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000/api
