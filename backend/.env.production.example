# ==============================================================
#  NEW WINE CHURCH — Template .env PRODUCTION
#  Copier en .env sur le serveur prod, puis personnaliser.
# ==============================================================

APP_NAME="New Wine Church"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Abidjan
APP_URL=https://newinechurch.org
FRONTEND_URL=https://newinechurch.org

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,json,sentry              # combinaison : daily lisible + json structuré + sentry erreurs
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null
LOG_DAILY_DAYS=30

# === Sentry (observabilité erreurs + perf) ===
SENTRY_LARAVEL_DSN=                      # ← DSN Sentry (https://docs.sentry.io)
SENTRY_TRACES_SAMPLE_RATE=0.2            # 20% des requêtes profilées
SENTRY_PROFILES_SAMPLE_RATE=0.2

# === Base de données MySQL prod ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=newwinechurch
DB_USERNAME=nwc_user
DB_PASSWORD=                       # ← générer un mdp fort

# === Sessions (Redis recommandé en prod) ===
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.newinechurch.org   # point devant = partage sous-domaines
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# === Sanctum SPA (cookie auth) ===
SANCTUM_STATEFUL_DOMAINS=newinechurch.org,www.newinechurch.org

# === Cache + Queue (Redis pour scale) ===
CACHE_STORE=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=public            # ou "s3" si stockage CDN externe

# === Redis ===
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                    # ← obligatoire en prod
REDIS_PORT=6379
REDIS_DB=0

# === Broadcasting (Reverb derrière nginx WebSocket proxy) ===
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=newwinechurch
REVERB_APP_KEY=                    # ← générer un random 32 chars
REVERB_APP_SECRET=                 # ← générer un random 64 chars
REVERB_HOST=newinechurch.org
REVERB_PORT=443
REVERB_SCHEME=https
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# === Mail (SMTP, SES, Postmark ou Resend) ===
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contact@newinechurch.org"
MAIL_FROM_NAME="${APP_NAME}"

# === Live Streaming Agora.io ===
AGORA_APP_ID=                      # ← console Agora
AGORA_APP_CERTIFICATE=             # ← console Agora
AGORA_TOKEN_EXPIRY=3600

# === Stockage S3 (optionnel mais recommandé prod) ===
# Décommenter pour activer S3 + changer FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-1
# AWS_BUCKET=nwc-media
# AWS_USE_PATH_STYLE_ENDPOINT=false

# === Telescope (toujours désactivé en prod) ===
TELESCOPE_ENABLED=false

# === Backup auto (Spatie laravel-backup) ===
# Cron : 0 2 * * * cd /var/www/nwc/backend && php artisan backup:run >> /var/log/nwc-backup.log
BACKUP_ARCHIVE_PASSWORD=           # ← chiffrer les backups
